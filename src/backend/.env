# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE - YAG BACKEND SERVICE
# Copy this file to .env and fill in the secrets for local development.
# ==============================================================================

# Application Settings
PROJECT_NAME="YAG - Smart Novel Writing Platform"
API_V1_STR="/api/v1"
SECRET_KEY="yag_development_secret_key_change_in_production"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration (PostgreSQL with pgvector extension)
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="yag"

# Redis Cache & Session Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# RabbitMQ Message Broker Configuration
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USER="yag_mq"
RABBITMQ_PASSWORD="yag_mq_secret"

# Google Gemini API Settings (U006 plot suggestions, U008 semantic embeddings, U013 moderation)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Cloudinary CDN Configuration (U002 user avatar, U003 story cover)
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME_HERE"
CLOUDINARY_API_KEY="YOUR_API_KEY_HERE"
CLOUDINARY_API_SECRET="YOUR_API_SECRET_HERE"

# VNPAY Sandbox Billing Configuration (U012 premium billing)
VNP_TMN_CODE="YOUR_VNPAY_TMN_CODE_HERE"
VNP_HASH_SECRET="YOUR_VNPAY_HASH_SECRET_HERE"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_RETURN_URL="http://localhost:3000/payment/result"
